[mysqld]
# 容器内存上限是 3G，这里给 InnoDB 预留 2G 缓冲池。
innodb_buffer_pool_size=2G

# 允许远程连接。
bind-address=0.0.0.0
skip-name-resolve

# 统一字符集。
character-set-server=utf8mb4
collation-server=utf8mb4_0900_ai_ci

# 最大连接数。
max_connections=300

# 慢查询日志。
slow_query_log=1
long_query_time=2
slow_query_log_file=/var/lib/mysql/slow.log
